{
  "$schema": "https://biomejs.dev/schemas/2.5.3/schema.json",
  "linter": {
    "enabled": true,
    "rules": {
      "preset": "recommended"
    }
  },
  "formatter": {
    "enabled": true,
    "indentStyle": "space",
    "indentWidth": 2,
    "lineWidth": 100,
    "lineEnding": "lf"
  },
  "javascript": {
    "formatter": {
      "quoteStyle": "double",
      "semicolons": "always",
      "trailingCommas": "all",
      "bracketSpacing": true,
      "arrowParentheses": "always"
    }
  },
  "files": {
    "includes": ["src/**/*", "scripts/**/*", "*.json", "*.md", "!.mcp.json"]
  }
}
